{
    "name": "api2convert/sdk",
    "description": "Official PHP SDK for the API2Convert file-conversion API. Convert, compress and transform images, documents, audio, video, ebooks, archives and CAD with one line of code.",
    "type": "library",
    "keywords": ["api2convert", "file conversion", "convert", "pdf", "image", "video", "audio", "ocr", "sdk", "api"],
    "homepage": "https://www.api2convert.com",
    "license": "MIT",
    "authors": [
        {
            "name": "Qaamgo Media GmbH",
            "homepage": "https://www.api2convert.com"
        }
    ],
    "support": {
        "docs": "https://www.api2convert.com/documentation",
        "issues": "https://github.com/QaamGo/api2convert-php/issues",
        "source": "https://github.com/QaamGo/api2convert-php"
    },
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "guzzlehttp/guzzle": "^7.5",
        "guzzlehttp/psr7": "^2.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "squizlabs/php_codesniffer": "^3.10",
        "php-http/mock-client": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Api2Convert\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Api2Convert\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse",
        "cs": "phpcs",
        "cs-fix": "phpcbf",
        "check": ["@cs", "@stan", "@test"]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
